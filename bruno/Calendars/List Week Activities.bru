meta {
  name: List Week Activities
  type: http
  seq: 9
}

get {
  url: {{baseUrl}}/api/v1/calendars/{{calendarId}}/weeks/{{week}}/activities
  body: none
  auth: none
}

vars:pre-request {
  calendarId: 70356d1a-d81b-4251-992b-c2897db69652
  week: 1
}

docs {
  Requires authenticated access_token cookie.
  Expected response: 200 OK with activities from the selected calendar and week.
}
