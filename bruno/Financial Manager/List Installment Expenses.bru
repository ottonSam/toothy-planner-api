meta {
  name: List Installment Expenses
  type: http
  seq: 22
}

get {
  url: {{baseUrl}}/api/v1/financial-manager/wallets/{{walletId}}/installment-expenses
}

vars:pre-request {
  walletId: 00000000-0000-0000-0000-000000000000
}

docs {
  Requires authenticated access_token cookie.
  Expected response: 200 OK.
}

