meta {
  name: Delete Wallet
  type: http
  seq: 10
}

delete {
  url: {{baseUrl}}/api/v1/financial-manager/wallets/{{walletId}}
}

vars:pre-request {
  walletId: 00000000-0000-0000-0000-000000000000
}

docs {
  Requires authenticated access_token cookie.
  Expected response: 204 No Content when wallet is unused.
}

