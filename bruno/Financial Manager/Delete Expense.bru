meta {
  name: Delete Expense
  type: http
  seq: 19
}

delete {
  url: {{baseUrl}}/api/v1/financial-manager/wallets/{{walletId}}/expenses/{{expenseId}}
}

vars:pre-request {
  walletId: 00000000-0000-0000-0000-000000000000
  expenseId: 00000000-0000-0000-0000-000000000000
}

docs {
  Requires authenticated access_token cookie.
  Expected response: 204 No Content.
}

