meta {
  name: Get Cycle Metrics
  type: http
  seq: 14
}

get {
  url: {{baseUrl}}/api/v1/financial-manager/wallets/{{walletId}}/cycles/{{cycleId}}/metrics
}

vars:pre-request {
  walletId: 00000000-0000-0000-0000-000000000000
  cycleId: 00000000-0000-0000-0000-000000000000
}

docs {
  Requires authenticated access_token cookie.
  Expected response: 200 OK with totals, remaining amounts and spendingByCategory for bar charts.
}
