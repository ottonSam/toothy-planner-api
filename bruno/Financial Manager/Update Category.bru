meta {
  name: Update Category
  type: http
  seq: 4
}

put {
  url: {{baseUrl}}/api/v1/financial-manager/categories/{{categoryId}}
  body: json
  auth: none
}

body:json {
  {
    "name": "Mercado",
    "color": "#22C55E",
    "icon": "shopping-cart"
  }
}

vars:pre-request {
  categoryId: 190e5224-d8f7-4df8-8a6f-2aa38efcf8ad
}

docs {
  Requires authenticated access_token cookie.
  Expected response: 200 OK.
}
