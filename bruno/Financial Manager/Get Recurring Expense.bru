meta {
  name: Get Recurring Expense
  type: http
  seq: 28
}

get {
  url: {{baseUrl}}/api/v1/financial-manager/wallets/{{walletId}}/recurring-expenses/{{recurringExpenseId}}
}

vars:pre-request {
  walletId: 00000000-0000-0000-0000-000000000000
  recurringExpenseId: 00000000-0000-0000-0000-000000000000
}

docs {
  Requires authenticated access_token cookie.
  Expected response: 200 OK.
}

