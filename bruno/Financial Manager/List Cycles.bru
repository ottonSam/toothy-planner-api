meta {
  name: List Cycles
  type: http
  seq: 12
}

get {
  url: {{baseUrl}}/api/v1/financial-manager/wallets/{{walletId}}/cycles
}

vars:pre-request {
  walletId: 00000000-0000-0000-0000-000000000000
}

docs {
  Requires authenticated access_token cookie.
  Cycles are created automatically by expenses, installments and recurrences.
}

