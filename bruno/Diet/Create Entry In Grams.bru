meta {
  name: Create Entry In Grams
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/v1/diet/entries
  body: json
}

body:json {
  {
    "foodName": "ovo",
    "quantity": 100.00,
    "unit": "GRAMS",
    "entryDate": "2026-07-13"
  }
}

docs {
  Requires authenticated access_token cookie.
  Creates the food through DeepSeek only if it does not exist for the user.
}

