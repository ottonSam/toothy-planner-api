SPRING_APPLICATION_NAME=toothy-planner-api

POSTGRES_IMAGE=postgres:18-alpine
POSTGRES_CONTAINER_NAME=toothy-planner-postgres
POSTGRES_DB=toothy_planner
POSTGRES_USER=toothy_planner
POSTGRES_PASSWORD=toothy_planner
POSTGRES_PORT=5432
POSTGRES_CONTAINER_PORT=5432
POSTGRES_DATA_PATH=.docker/postgres/data
POSTGRES_CONTAINER_DATA_PATH=/var/lib/postgresql/data

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/toothy_planner
SPRING_DATASOURCE_USERNAME=toothy_planner
SPRING_DATASOURCE_PASSWORD=toothy_planner
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_URL=jdbc:postgresql://localhost:5432/toothy_planner
SPRING_FLYWAY_USER=toothy_planner
SPRING_FLYWAY_PASSWORD=toothy_planner

MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_CONTAINER_NAME=toothy-planner-minio
MINIO_ROOT_USER=toothy_planner_minio
MINIO_ROOT_PASSWORD=toothy_planner_minio_password
MINIO_API_PORT=9000
MINIO_API_CONTAINER_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_CONSOLE_CONTAINER_PORT=9001
MINIO_DATA_PATH=.docker/minio/data
MINIO_CONTAINER_DATA_PATH=/data
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=toothy_planner_minio
MINIO_SECRET_KEY=toothy_planner_minio_password
MINIO_BUCKET=toothy-planner
