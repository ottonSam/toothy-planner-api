SPRING_APPLICATION_NAME=toothy-planner-api

API_CONTAINER_NAME=toothy-planner-api
API_PORT=8080

POSTGRES_IMAGE=postgres:18-alpine
POSTGRES_CONTAINER_NAME=toothy-planner-postgres
POSTGRES_DB=toothy_planner
POSTGRES_USER=toothy_planner
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5433
POSTGRES_CONTAINER_PORT=5432
POSTGRES_DATA_PATH=.docker/postgres/pg18
POSTGRES_CONTAINER_DATA_PATH=/var/lib/postgresql

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/toothy_planner
SPRING_DATASOURCE_USERNAME=toothy_planner
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_URL=jdbc:postgresql://localhost:5433/toothy_planner
SPRING_FLYWAY_USER=toothy_planner
SPRING_FLYWAY_PASSWORD=change-me

MINIO_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
MINIO_CONTAINER_NAME=toothy-planner-minio
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me
MINIO_API_PORT=9000
MINIO_API_CONTAINER_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_CONSOLE_CONTAINER_PORT=9001
MINIO_DATA_PATH=.docker/minio/data
MINIO_CONTAINER_DATA_PATH=/data
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=toothy-planner

APP_JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-characters
APP_JWT_ISSUER=toothy-planner-api

DEEPSEEK_API_KEY=change-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:8082,http://127.0.0.1:8082
